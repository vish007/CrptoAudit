[flake8]
max-line-length = 120
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    migrations,
    .eggs,
    *.egg-info,
    build,
    dist,
    .tox,
    .pytest_cache,
    .mypy_cache
ignore =
    E501,
    W503,
    E203
max-complexity = 10
per-file-ignores =
    __init__.py:F401,F403
    tests/*:F401,F841,E501
docstring-convention = google
import-order-style = google

# =============================================================================
# SimplyFI Proof of Reserves Platform - Environment Configuration Template
# =============================================================================
# Copy this file to .env and configure with your actual values
# DO NOT commit .env file with sensitive data to version control
# =============================================================================

# APPLICATION SETTINGS
# =============================================================================
APP_NAME=SimplyFI Proof of Reserves Platform
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO

# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string for async operations
DATABASE_URL=postgresql+asyncpg://por_user:por_password@postgres:5432/por_db

# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# REDIS CONFIGURATION
# =============================================================================
# Primary Redis for caching
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# CELERY CONFIGURATION
# =============================================================================
# Celery broker (message queue)
CELERY_BROKER_URL=redis://redis:6379/1

# Celery result backend (store task results)
CELERY_RESULT_BACKEND=redis://redis:6379/2

# S3 / MinIO CONFIGURATION
# =============================================================================
# S3-compatible storage endpoint (MinIO in Docker, AWS S3 in production)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=simplyfi-por-reports
S3_REGION=us-east-1

# For AWS S3, use these instead:
# S3_ENDPOINT=https://s3.amazonaws.com
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# JWT CONFIGURATION
# =============================================================================
# Secret key for JWT token signing (use strong random value in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-super-secret-key-change-in-production-12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# SECURITY SETTINGS
# =============================================================================
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_SPECIAL=True
MFA_ENABLED_BY_DEFAULT=True
MFA_ISSUER=SimplyFI
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# CORS SETTINGS
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost,http://nginx:80,http://frontend:3000
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=*

# AI/ML CONFIGURATION
# =============================================================================
# Local LLM model settings (optional)
LLAMA_MODEL_PATH=/models/llama-2-7b-chat.gguf
ENABLE_LOCAL_LLM=False
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MAX_TOKENS_PER_REQUEST=4096

# BLOCKCHAIN API CONFIGURATION
# =============================================================================
# Etherscan API key for Ethereum verification
ETHERSCAN_API_KEY=your_etherscan_api_key

# Infura API key for Ethereum RPC
INFURA_API_KEY=your_infura_api_key

# Alchemy API key for Ethereum RPC
ALCHEMY_API_KEY=your_alchemy_api_key

# Blockstream API key for Bitcoin
BLOCKSTREAM_API_KEY=optional_blockstream_api_key

# SolScan API key for Solana
SOLSCAN_API_KEY=your_solscan_api_key

# BSCScan API key for Binance Smart Chain
BSCSCAN_API_KEY=your_bscscan_api_key

# Blockchain API timeout (seconds)
BLOCKCHAIN_API_TIMEOUT=30

# VARA COMPLIANCE SETTINGS
# =============================================================================
# Virtual Asset Reference Architecture (VARA) compliance settings
VARA_LICENSE_NUMBER=VARA-001-2024
VARA_COMPLIANCE_LEVEL=LEVEL_3
VARA_AUDIT_RETENTION_YEARS=7
VARA_MIN_RESERVE_RATIO=0.95

# EMAIL CONFIGURATION (SMTP)
# =============================================================================
# For sending notifications and alerts
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@simplyfi.com

# Optional: For AWS SES
# SMTP_SERVER=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your_ses_smtp_user
# SMTP_PASSWORD=your_ses_smtp_password

# NOTIFICATION SETTINGS
# =============================================================================
# Enable/disable various notification channels
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_SLACK_NOTIFICATIONS=False
ENABLE_WEBHOOK_NOTIFICATIONS=True

# Slack webhook URL (if enabled)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# LOGGING CONFIGURATION
# =============================================================================
LOG_FORMAT=json
LOG_FILE=/app/logs/simplyfi.log
LOG_MAX_BYTES=104857600
LOG_BACKUP_COUNT=10

# FEATURE FLAGS
# =============================================================================
# Feature flags for gradual rollout
ENABLE_DeFI_VERIFICATION=True
ENABLE_MERKLE_TREE_EXPORT=True
ENABLE_VARA_REPORTS=True
ENABLE_ADVANCED_ANALYTICS=False

# TESTING CONFIGURATION
# =============================================================================
# Only used during testing
TESTING=False
TEST_DATABASE_URL=postgresql+asyncpg://por_user:por_password@postgres:5432/por_test_db

# EXTERNAL SERVICE INTEGRATIONS
# =============================================================================
# Optional integrations with external services

# CoinGecko API (free tier available)
COINGECKO_API_KEY=optional

# CoinMarketCap API
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key

# Messari API for market data
MESSARI_API_KEY=your_messari_api_key

# CUSTOM SETTINGS
# =============================================================================
# Add any additional custom settings below

# Maximum file upload size (bytes)
MAX_UPLOAD_SIZE=104857600

# Session timeout (minutes)
SESSION_TIMEOUT=30

# Enable debug mode (only in development)
ENABLE_DEBUG_ENDPOINTS=False

# API rate limiting (requests per minute)
API_RATE_LIMIT_DEFAULT=60
API_RATE_LIMIT_AUTH=5
API_RATE_LIMIT_API=30

# Task retry settings
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_RETRY_DELAY=300

# Webhook timeout (seconds)
WEBHOOK_TIMEOUT=30
WEBHOOK_MAX_RETRIES=3

# Data retention settings (days)
AUDIT_LOG_RETENTION_DAYS=365
TASK_LOG_RETENTION_DAYS=90
TEMPORARY_FILE_RETENTION_DAYS=7

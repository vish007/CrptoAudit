# API Configuration
REACT_APP_API_URL=http://localhost:3001/api
REACT_APP_WS_URL=ws://localhost:3001

# Environment
REACT_APP_ENV=development

# Feature Flags
REACT_APP_ENABLE_2FA=true
REACT_APP_ENABLE_AUDIT_LOGS=true
REACT_APP_ENABLE_AI_AGENTS=true

# Token Configuration
REACT_APP_TOKEN_EXPIRY=3600
REACT_APP_REFRESH_TOKEN_EXPIRY=604800
REACT_APP_SESSION_TIMEOUT=1800000

# Analytics
REACT_APP_ANALYTICS_ENABLED=false
REACT_APP_ANALYTICS_ID=

# Blockchain Networks
REACT_APP_SUPPORTED_NETWORKS=ethereum,bitcoin,polygon,arbitrum,optimism,solana,cardano
